    "@vue/eslint-config-prettier": "^10.2.0",
    "eslint": "^9.29.0",
    "eslint-plugin-vue": "~10.2.0",
    "gh-pages": "^6.3.0",
    "globals": "^16.2.0",
    "prettier": "3.5.3",
    "terser": "^5.46.0",
    "vite": "^7.0.0",
    "vite-plugin-vue-devtools": "^7.7.7"
